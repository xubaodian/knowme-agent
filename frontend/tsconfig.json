{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "./next-env.d.ts",
    "./app/**/*.ts",
    "./app/**/*.tsx",
    "./components/**/*.ts",
    "./components/**/*.tsx",
    "./lib/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

