{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "sourceMap": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["src/agent/**/*.ts", "src/logging/**/*.ts", "src/server/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/web"]
}
